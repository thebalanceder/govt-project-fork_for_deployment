# =============================================================================
# CSPOPS MALAYSIA - Complete API Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
# ALL APIs listed below have FREE tiers suitable for government use.
# =============================================================================

# =============================================================================
# SOCIAL MEDIA APIs (Required for social media data)
# =============================================================================

# Reddit API - For r/malaysia and other Malaysian subreddits
# Get: https://www.reddit.com/prefs/apps
# Free tier: 60 requests/minute
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=CSPOPS/2.0 (by /u/your_username)

# Twitter/X API - For Malaysian tweets
# Get: https://developer.twitter.com/en/portal/dashboard
# Free tier: 500 tweets/month
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Telegram API - For Malaysian Telegram channels
# Get: https://my.telegram.org/apps
# Free tier: Unlimited
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here

# =============================================================================
# NEWS APIs (Required for news articles)
# =============================================================================

# NewsAPI - For global and Malaysian news
# Get: https://newsapi.org/register
# Free tier: 100 requests/day
NEWSAPI_KEY=your_newsapi_key_here

# GNews API - Backup news source
# Get: https://gnews.io/
# Free tier: 100 requests/day
GNEWS_KEY=your_gnews_key_here

# =============================================================================
# ECONOMIC DATA APIs (Required for economic indicators)
# =============================================================================

# Exchange Rate API - For USD/MYR exchange rates (NO KEY NEEDED)
# Free tier: 1000 requests/month
# No configuration needed - works out of the box

# Yahoo Finance - For KLCI stock data (NO KEY NEEDED)
# Free tier: Unlimited
# No configuration needed - works out of the box (requires yfinance package)

# API Ninjas - For oil prices (NO KEY NEEDED for demo)
# Free tier: 100 requests/day
# No configuration needed - demo key works

# FRED API - For global economic indicators
# Get: https://fred.stlouisfed.org/docs/api/api_key.html
# Free tier: 120 requests/minute
FRED_API_KEY=your_fred_api_key_here

# Trading Economics API - For additional economic indicators
# Get: https://developer.tradingeconomics.com/
# Free tier: 2000 requests/day
TRADING_ECONOMICS_KEY=your_trading_economics_key_here

# World Bank API - For development indicators (NO KEY NEEDED)
# Free tier: Unlimited
# No configuration needed - works out of the box

# IMF API - For international financial data (NO KEY NEEDED)
# Free tier: Unlimited
# No configuration needed - works out of the box

# Bank Negara Malaysia (BNM) API - For Malaysian economic data (NO KEY NEEDED)
# Free tier: Unlimited
# No configuration needed - works out of the box

# Department of Statistics Malaysia (DOSM) API (NO KEY NEEDED)
# Free tier: Unlimited
# No configuration needed - works out of the box

# BLS API - For US labor statistics (optional, affects Malaysia)
# Get: https://www.bls.gov/developers/api_registration.htm
# Free tier: 500 requests/hour
BLS_API_KEY=your_bls_api_key_here

# =============================================================================
# AI/LLM APIs (Required for AI analysis and chatbot)
# =============================================================================

# OpenRouter API - For AI chatbot and analysis
# Get: https://openrouter.ai/keys
# Free tier: Varies by model
OPENROUTER_API_KEY=your_openrouter_api_key_here
USE_OPENROUTER=true

# DeepSeek API (Alternative to OpenRouter)
# Get: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# =============================================================================
# WEB CRAWLING (Optional for additional data)
# =============================================================================

# Playwright - For web crawling (NO KEY NEEDED)
# Free tier: Unlimited
# No configuration needed - requires playwright package installation

# Lightpanda Browser - Alternative web crawler (NO KEY NEEDED)
# Get: https://github.com/lightpanda-io/browser
# Free tier: Unlimited
LIGHTPANDA_PATH=/usr/local/bin/lightpanda
LIGHTPANDA_WS_URL=ws://localhost:9222

# =============================================================================
# COLLECTION SETTINGS
# =============================================================================

# Keywords to search for in data collection
COLLECTION_KEYWORDS=Malaysia economy,Bank Negara,KLCI,ringgit,inflation,cost of living

# Subreddits to monitor (comma-separated)
REDDIT_SUBREDDITS=malaysia,askmalaysia,malaysianews,kl,penang,johorbahru,sarawak,sabah

# Twitter search queries (comma-separated)
TWITTER_QUERIES=Malaysia economy,Bank Negara,KLCI,ringgit,inflation Malaysia

# Telegram channels to monitor (comma-separated)
TELEGRAM_CHANNELS=malaysianews,malaysiaupdates,klfoodie,malaysiaproperty

# Maximum items to collect per source
MAX_ITEMS_PER_SOURCE=100

# Days of backdata to collect
DAYS_BACK=7

# Enable/disable specific data sources
ENABLE_REDDIT=true
ENABLE_TWITTER=true
ENABLE_TELEGRAM=true
ENABLE_NEWSAPI=true
ENABLE_GNEWS=true
ENABLE_FRED=true
ENABLE_TRADING_ECONOMICS=true
ENABLE_WORLD_BANK=true
ENABLE_IMF=true
ENABLE_BNM=true
ENABLE_DOSM=true
ENABLE_WEB_CRAWLING=true

# =============================================================================
# OPTIONAL: US Government APIs (For comparison/international context)
# =============================================================================

# data.gov API - For US government data (optional)
# Get: https://api.data.gov/
# Free tier: Varies by API
DATA_GOV_API_KEY=your_data_gov_api_key_here

# =============================================================================
# SYSTEM SETTINGS
# =============================================================================

# Geographic focus
COUNTRY=Malaysia
STATE=
CITY=

# Logging level
LOG_LEVEL=INFO

# Data retention (days)
DATA_RETENTION_DAYS=30
